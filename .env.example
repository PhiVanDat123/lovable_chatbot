# Bắt buộc: Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Đường dẫn 3 file nguồn (Windows dùng \\ hoặc /)
PRODUCTS_CSV=C:/Users/Admin/Downloads/holistic_way_products.csv
POLICY_DOCX=C:/Users/Admin/Downloads/policy_data.docx
NUTRITION_DOCX=C:/Users/Admin/Downloads/nutrition_data.docx

# Thư mục lưu index vector (mặc định: bộ nhớ cục bộ, phản hồi nhanh)
INDEX_DIR=./data_index

# Model (Flash = nhanh, phù hợp ~3s)
CHAT_MODEL=gemini-2.0-flash
EMBED_MODEL=text-embedding-004
TOP_K=10

# memory | firestore  (firestore cần GCP + vector index)
VECTOR_BACKEND=memory

# Firestore (khi VECTOR_BACKEND=firestore)
GOOGLE_CLOUD_PROJECT=
FIRESTORE_COLLECTION=holistic_rag_chunks

# GCS tùy chọn — chỉ dùng khi chạy scripts/gcs_upload_sources.py
GCS_BUCKET=
